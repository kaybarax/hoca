# GitHub (required for PR creation and issue dispatch)
GITHUB_TOKEN=
GITHUB_REPOSITORY=

# Webhook listener (required only for GitHub issue automation)
# Enable this only when you have configured a signed GitHub Actions webhook.
HOCA_WEBHOOK_ENABLED=false
HOCA_WEBHOOK_SECRET=
HOCA_WEBHOOK_URL=
HOCA_WORKSPACE_ROOT=~/code
# Optional comma-separated owner/repo allowlist. Leave empty to allow any repo
# under HOCA_WORKSPACE_ROOT.
HOCA_ALLOWED_REPOS=
HOCA_MAX_WEBHOOK_BYTES=65536

# Telegram notifications (optional)
HOCA_NOTIFY_TELEGRAM=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Ollama (required — local LLM runtime)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen-14b-pro
# Doctor uses this for the hardware recommendation only.
HOCA_RECOMMENDED_RAM_GB=48

# OpenHands LLM (required)
LLM_MODEL=ollama/qwen-14b-pro
LLM_BASE_URL=http://127.0.0.1:11434
LLM_API_KEY=ollama
# Worker execution limits in seconds.
HOCA_OPENHANDS_TIMEOUT=600
HOCA_OPENHANDS_STALL=300

# If OpenHands runs inside Docker and must reach host Ollama:
# LLM_BASE_URL=http://host.docker.internal:11434

# Aider (required — used for diff review)
AIDER_MODEL=ollama_chat/qwen-14b-pro

# HOCA defaults (safe values — change only if you understand the implications)
HOCA_AUTO_MERGE=false
HOCA_REQUIRE_AIDER_LGTM=true
HOCA_REQUIRE_TESTS=true
HOCA_STOP_ON_DIRTY_TREE=true
# Maximum OpenHands repair passes after current-task test failures or Aider review feedback.
HOCA_MAX_REPAIR_ATTEMPTS=2
# When true, hoca run calls init-project before starting a task.
HOCA_RUN_INIT_PROJECT=false
