# GitHub (required for PR creation and issue dispatch)
GITHUB_TOKEN=
GITHUB_REPOSITORY=

# Webhook listener (required only for GitHub issue automation)
HOCA_WEBHOOK_SECRET=
HOCA_WEBHOOK_URL=
HOCA_WORKSPACE_ROOT=~/code
HOCA_ALLOWED_REPOS=
HOCA_MAX_WEBHOOK_BYTES=65536

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Ollama (required — local LLM runtime)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen-32b-pro

# OpenHands LLM (required)
LLM_MODEL=ollama/qwen-32b-pro
LLM_BASE_URL=http://127.0.0.1:11434
LLM_API_KEY=ollama

# If OpenHands runs inside Docker and must reach host Ollama:
# LLM_BASE_URL=http://host.docker.internal:11434

# Aider (required — used for diff review)
AIDER_MODEL=ollama_chat/qwen-32b-pro

# HOCA defaults (safe values — change only if you understand the implications)
HOCA_AUTO_MERGE=false
HOCA_REQUIRE_AIDER_LGTM=true
HOCA_REQUIRE_TESTS=true
HOCA_STOP_ON_DIRTY_TREE=true
