# GitHub (manager-only: PR creation and issue dispatch; not forwarded to worker/reviewer sandboxes)
GITHUB_TOKEN=
GITHUB_REPOSITORY=

# Webhook listener (required only for GitHub issue automation)
# Enable this only when you have configured a signed GitHub Actions webhook.
HOCA_WEBHOOK_ENABLED=false
HOCA_WEBHOOK_SECRET=
HOCA_WEBHOOK_URL=
HOCA_WORKSPACE_ROOT=~/code
# Optional comma-separated owner/repo allowlist. Leave empty to allow any repo
# under HOCA_WORKSPACE_ROOT.
HOCA_ALLOWED_REPOS=
HOCA_MAX_WEBHOOK_BYTES=65536

# Telegram notifications (optional)
HOCA_NOTIFY_TELEGRAM=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Ollama (local LLM runtime — used when LLM_MODEL starts with ollama/)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen-14b-pro
# Legacy aliases (still accepted during transition):
#   OLLAMA_HOST — falls back to OLLAMA_BASE_URL
#   OLLAMA_API_BASE — falls back to OLLAMA_BASE_URL (used by Aider historically)
# Doctor uses this for the hardware recommendation only.
HOCA_RECOMMENDED_RAM_GB=48

# ─── LLM Provider Configuration ───────────────────────────────────────────────
# Legacy single-model mode: choose ONE provider by setting LLM_MODEL with the
# appropriate prefix. This remains active when all role model blocks below are
# empty.
#
# --- Ollama (local, default) ---
LLM_MODEL=ollama/qwen-14b-pro
LLM_BASE_URL=http://127.0.0.1:11434
LLM_API_KEY=ollama
#
# --- LM Studio (local, OpenAI-compatible) ---
# LLM_MODEL=openai/gpt-oss-20b
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_API_KEY=lm-studio
#
# --- DeepSeek (cloud) ---
# LLM_MODEL=deepseek/deepseek-v4-flash
# LLM_BASE_URL=
# LLM_API_KEY=<your-deepseek-api-key>
#
# --- Gemini (cloud) ---
# LLM_MODEL=gemini/gemini-2.0-flash
# LLM_BASE_URL=
# LLM_API_KEY=<your-gemini-api-key>
#
# --- Other litellm-supported providers ---
# LLM_MODEL=together_ai/meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo
# LLM_BASE_URL=
# LLM_API_KEY=<your-api-key>
# ───────────────────────────────────────────────────────────────────────────────

# Optional role model pool for manager/worker/reviewer phases. Leave every
# HOCA_*_MODEL_MODEL empty to preserve legacy LLM_MODEL, LLM_BASE_URL, and
# LLM_API_KEY behavior.
#
# Only the selected role model is forwarded to worker/reviewer execution as
# LLM_MODEL, LLM_BASE_URL, and LLM_API_KEY. Raw role model credentials stay in
# manager-side configuration and are stripped before phase execution.
#
# Example local-first role pool (uncomment to enable):
# HOCA_MANAGER_MODEL_NAME=manager
# HOCA_MANAGER_MODEL_MODEL=ollama/qwen-7b-pro
# HOCA_MANAGER_MODEL_BASE_URL=http://127.0.0.1:11434
# HOCA_MANAGER_MODEL_API_KEY=ollama
# HOCA_WORKER_MODEL_NAME=worker
# HOCA_WORKER_MODEL_MODEL=ollama/qwen-14b-pro
# HOCA_WORKER_MODEL_BASE_URL=http://127.0.0.1:11434
# HOCA_WORKER_MODEL_API_KEY=ollama
# HOCA_REVIEWER_MODEL_NAME=reviewer
# HOCA_REVIEWER_MODEL_MODEL=openai/gpt-oss-20b
# HOCA_REVIEWER_MODEL_BASE_URL=http://localhost:1234/v1
# HOCA_REVIEWER_MODEL_API_KEY=lm-studio
HOCA_MANAGER_MODEL_NAME=
HOCA_MANAGER_MODEL_MODEL=
HOCA_MANAGER_MODEL_BASE_URL=
HOCA_MANAGER_MODEL_API_KEY=

HOCA_WORKER_MODEL_NAME=
HOCA_WORKER_MODEL_MODEL=
HOCA_WORKER_MODEL_BASE_URL=
HOCA_WORKER_MODEL_API_KEY=

HOCA_REVIEWER_MODEL_NAME=
HOCA_REVIEWER_MODEL_MODEL=
HOCA_REVIEWER_MODEL_BASE_URL=
HOCA_REVIEWER_MODEL_API_KEY=

# Upgrade migration flags. Keep these defaults to run the existing script-backed
# workflow during migration. Kanban is an advanced durable multi-agent mode and
# is not required for basic `hoca run`.
HOCA_USE_HERMES_PROFILES=false
HOCA_USE_STRUCTURED_REPORTS=true
HOCA_USE_KANBAN=false
HOCA_MAX_TOTAL_ROUNDS=3

# Worker execution limits in seconds.
HOCA_OPENHANDS_TIMEOUT=600
HOCA_OPENHANDS_STALL=300

# Docker sandbox (recommended default: keep true for autonomous worker/reviewer runs)
# When true, OpenHands runs inside one HOCA-controlled container with bun/node/pnpm
# pre-installed. The container has network access for package installation but is
# isolated from the host filesystem (only the project worktree is mounted).
# Set to false only for explicit host-local execution (higher risk; see README).
HOCA_USE_SANDBOX=true
# When true, HOCA creates a disposable Git worktree for each run so the
# worker/reviewer operate on a copy rather than the user's active checkout.
# The worktree lives at .hoca-runtime/worktrees/<run_id>/ and is removed on
# cleanup. This avoids contaminating the active checkout with agent changes.
HOCA_USE_WORKTREE_SANDBOX=true
# HOCA removes target-repo .hoca-runtime on run exit and archives each run
# outside the target checkout for later inspection.
# Default archive root: ~/.hoca/runtime-archives/<repo-name>/<run-id>/
# Set HOCA_KEEP_RUNTIME=true only for immediate local debugging.
# HOCA_RUNTIME_ARCHIVE_ROOT=/Users/you/.hoca/runtime-archives
# HOCA_KEEP_RUNTIME=false
# Sandbox outbound network for worker/reviewer containers.
# offline: no external egress (--network none); safest after dependencies exist.
# package-install: Docker bridge; allows registry fetches but is not allowlisted.
# github-only: Docker bridge; GitHub-only egress is not enforced by Docker alone.
# full: unrestricted bridge egress; explicit opt-in only (set this var or task spec).
HOCA_NETWORK_MODE=offline
# HOCA_NETWORK_MODE=package-install
# HOCA_NETWORK_MODE=full
# Sandbox resource limits
HOCA_SANDBOX_MEMORY=8g
HOCA_SANDBOX_PIDS=512
# Custom sandbox image (default: hoca-sandbox:latest, built from docker/Dockerfile.sandbox)
# HOCA_SANDBOX_IMAGE=hoca-sandbox:latest

# HOCA defaults (safe values — change only if you understand the implications)
# Branch HOCA switches to before creating each task branch. Set this to your
# team's development branch, for example main, master, or develop.
HOCA_DEV_BRANCH=main
# When true and an origin remote exists, HOCA fetches origin/$HOCA_DEV_BRANCH
# and creates task branches from that latest remote ref.
HOCA_SYNC_DEV_BRANCH=true
# When true, after a successful PR HOCA checks out the dev branch (or the
# pre-run branch when HOCA_DEV_BRANCH is unset) so the local repo returns to
# normal work. Skipped when uncommitted non-runtime changes would be lost.
HOCA_RESTORE_DEV_BRANCH=true
# When true, HOCA stages the reviewed changed-file set after LGTM and then
# continues to commit, push, PR creation, and runtime cleanup.
HOCA_AUTO_STAGE_REVIEWED_CHANGES=true
HOCA_AUTO_MERGE=false
HOCA_REQUIRE_TESTS=true
# Review approval gate. Legacy alias HOCA_REQUIRE_AIDER_LGTM is still accepted.
HOCA_REQUIRE_REVIEW=true
HOCA_STOP_ON_DIRTY_TREE=true
# Total worker/review/repair rounds (default: 3). Round 1 is the initial
# implementation + review; rounds 2-3 are repair + review cycles.
# Legacy alias: HOCA_MAX_REPAIR_ATTEMPTS is still accepted (value + 1 = rounds).
# HOCA_MAX_REPAIR_ATTEMPTS=2
# When true, hoca run calls init-project before starting a task.
HOCA_RUN_INIT_PROJECT=false
