#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
if [ -n "${HOCA_PYTHON:-}" ]; then
  PYTHON_BIN="$HOCA_PYTHON"
elif [ -x "$REPO_ROOT/.venv/bin/python" ]; then
  PYTHON_BIN="$REPO_ROOT/.venv/bin/python"
elif command -v python3 >/dev/null 2>&1; then
  PYTHON_BIN="python3"
else
  echo "python3 is required. Set HOCA_PYTHON or create .venv with HOCA dependencies."
  exit 1
fi

PYTHONPATH="$REPO_ROOT" "$PYTHON_BIN" -m hoca.cli "$@"
